{
  "ConnectionStrings": {
    "Default": "Server=(localdb)\\MSSQLLocalDB;Database=WIMS;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "WIMS",
    "Audience": "WIMS.Client",
    "SigningKey": "CHANGE_ME_dev_only_super_secret_key_min_32_bytes_long_1234567890",
    "ExpiryMinutes": 120
  },
  "Serilog": {
    "//Using": "لازم للنشر single-file — Serilog لا يكتشف مجمّعات الـ sinks تلقائياً في هذا الوضع.",
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/wims-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30
        }
      }
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Alerts": {
    "ScanIntervalMinutes": 60,
    "NearExpiryDays": 30,
    "StagnantDays": 90
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "EnableSsl": true,
    "User": "",
    "Password": "",
    "From": "wims@moj.local",
    "FromName": "نظام WIMS",
    "AlertRecipients": []
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:4200" ]
  },
  "RateLimiting": {
    "Enabled": true,
    "PermitPerMinute": 120,
    "Login": {
      "PermitPerMinute": 10
    }
  },
  "AllowedHosts": "*"
}
