<?xml version="1.0" encoding="utf-8"?>
<!--
  إعداد استضافة WIMS على IIS عبر ASP.NET Core Module V2 (استضافة داخل العملية).
  متغيّرات البيئة الحسّاسة (سلسلة الاتصال ومفتاح JWT) تُضبط في IIS → Configuration Editor
  أو عبر environmentVariables أدناه (يُفضّل حقنها من خارج ملف الحل، لا كتابتها في المستودع).
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\WIMS.WebApi.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- عيّن هذه من خارج المستودع (سطر أوامر النشر / IIS):
          <environmentVariable name="ConnectionStrings__Default" value="..." />
          <environmentVariable name="Jwt__SigningKey" value="..." />
          -->
        </environmentVariables>
      </aspNetCore>

      <!-- إزالة ترويسة الخادم (تقليل بصمة المعلومات). -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
        </customHeaders>
      </httpProtocol>

      <!-- حد حجم الطلب (10 ميغابايت) لملفات الاستيراد Excel. -->
      <security>
        <requestFiltering>
          <requestLimits maxAllowedContentLength="10485760" />
        </requestFiltering>
      </security>
    </system.webServer>
  </location>
</configuration>
