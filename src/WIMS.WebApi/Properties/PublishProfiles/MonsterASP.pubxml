<?xml version="1.0" encoding="utf-8"?>
<!--
  ملف تعريف نشر WebDeploy لموقع MonsterASP.NET — يحتوي فقط بيانات غير سرّية (مستخرجة من
  ملف *.publishSettings الذي يُنزَّل من لوحة التحكّم). كلمة المرور تُمرَّر وقت التشغيل فقط
  (عبر /p:Password="..." في سطر الأوامر) ولا تُكتب هنا أبداً — راجع DEPLOY-MonsterASP-AR.md.
-->
<Project>
  <PropertyGroup>
    <WebPublishMethod>MSDeploy</WebPublishMethod>
    <LastUsedBuildConfiguration>Release</LastUsedBuildConfiguration>
    <LastUsedPlatform>Any CPU</LastUsedPlatform>
    <SiteUrlToLaunchAfterPublish>http://invmoj.runasp.net/</SiteUrlToLaunchAfterPublish>
    <LaunchSiteAfterPublish>false</LaunchSiteAfterPublish>
    <MSDeployServiceURL>site77694.siteasp.net</MSDeployServiceURL>
    <DeployIisAppPath>site77694</DeployIisAppPath>
    <SkipExtraFilesOnServer>false</SkipExtraFilesOnServer>
    <MSDeployPublishMethod>WMSVC</MSDeployPublishMethod>
    <EnableMSDeployBackup>false</EnableMSDeployBackup>
    <UserName>site77694</UserName>
    <_SavePWD>False</_SavePWD>
    <SelfContained>false</SelfContained>
    <RuntimeIdentifier>win-x86</RuntimeIdentifier>
    <PublishProvider>MSDeploy</PublishProvider>
  </PropertyGroup>
</Project>
